<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
    <title>Jethro Burke VR</title>
    <script src="https://aframe.io/releases/1.5.0/aframe.min.js"></script>
        <script src="https://unpkg.com/aframe-environment-component/dist/aframe-environment-component.min.js"></script>

</head>
<body>
    <a-scene>
        <!--Assets-->
        <a-assets>
            <img id="juicewrld" src="images/faceScream.jpg" preload="auto">
            <img id="ent" src="images/entertainer.jpg" preload="auto">
        </a-assets>
        <a-entity environment="preset: tron; dressingAmount: 500; skyColor:#5603AD"></a-entity>
        <!--Museum Start--> 
         <a-cylinder id="floor" position="0 0 0" height="0.1" color="red"></a-cylinder>
        <a-box id="wall" position="0 1.473 4.907" scale="10 3 0.1" color="#5603AD"></a-box>
        <a-box id="wall2" position="0 1.473 -4.907" scale="10 3 0.1" color="#5603AD"></a-box>
        <a-box id="wall3" position="5.049 1.454 -0.008" rotation="0 -90 0"scale="10 3 0.1" color="#5603AD"></a-box>
        <a-box id="wall4" position="-5.049 1.454 -0.008" rotation="0 -90 0" scale="10 3 0.1" color="#5603AD"></a-box>
        <!--Roof-->
        <a-cylinder id="triangle_front" segments-radial="3" position="0 3.874 4.907" rotation="-90 0 0" scale="5.774 0.2 1.8" color="gray"></a-cylinder>
        <a-cylinder id="triangle_back" segments-radial="3" position="0 3.874 -4.907" rotation="-90 0 0" scale="5.774 0.2 1.8" color="pink"></a-cylinder>
        <a-box id="roof_right" position="2.580 4.328 0" rotation="28.433 90 0" scale="10.931 0.20 6.110" color="silver"></a-box>
        <a-box id="roof_left" position="-2.599 4.321 -0.017" rotation="28.433 -90 0" scale="10.931 0.20 6.130" color="silver"></a-box>
        <!--Art-->
        <a-plane id="art1" src="#juicewrld" scale="2 2 0.05" rotation="0 0 0" position="-0.162 1.934 -4.792"></a-plane>


    </a-scene>
</body>
</html> 


